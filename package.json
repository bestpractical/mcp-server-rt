{
  "name": "mcp-server-rt",
  "version": "0.1.0",
  "description": "MCP server for RT (Request Tracker)",
  "license": "Artistic-2.0",
  "author": "Best Practical Solutions, LLC",
  "homepage": "https://github.com/bestpractical/mcp-server-rt",
  "bin": {
    "mcp-server-rt": "dist/index.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "tsup": {
    "entry": ["src/index.ts"],
    "format": ["cjs"],
    "target": "node18",
    "banner": {
      "js": "#!/usr/bin/env node"
    },
    "clean": true
  }
}
