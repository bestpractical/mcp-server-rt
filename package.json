{
  "name": "mcp-server-rt",
  "version": "0.2.0",
  "description": "MCP server for RT (Request Tracker)",
  "license": "GPL-2.0",
  "author": "Best Practical Solutions, LLC",
  "homepage": "https://github.com/bestpractical/mcp-server-rt",
  "bin": {
    "mcp-server-rt": "dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "icon.png",
    "manifest.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "TZ=UTC vitest run",
    "test:watch": "TZ=UTC vitest",
    "pack": "rm -rf /tmp/mcp-server-rt-pack && mkdir /tmp/mcp-server-rt-pack && cp -r dist data manifest.json icon.png package.json /tmp/mcp-server-rt-pack/ && cd /tmp/mcp-server-rt-pack && npm install --omit=dev && cd - && mcpb pack /tmp/mcp-server-rt-pack mcp-server-rt.mcpb"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "tsup": {
    "entry": ["src/index.ts"],
    "format": ["cjs"],
    "target": "node18",
    "banner": {
      "js": "#!/usr/bin/env node"
    },
    "clean": true
  }
}
